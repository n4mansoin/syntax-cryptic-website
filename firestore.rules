
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this prototype, we'll identify the admin by their specific email address
      return isAuthenticated() && request.auth.token.email == "admins@intra-syntax.com";
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated() && (request.auth.uid == teamId || isAdmin());
      // Allow teams to create/update their own profiles for this prototype
      allow write: if (isAuthenticated() && request.auth.uid == teamId) || isAdmin();
    }

    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hints/{hintId} {
      allow read: if isAuthenticated() && (resource.data.isReleased == true || isAdmin());
      allow write: if isAdmin();
    }

    match /hintRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.teamId == request.auth.uid);
      allow write: if isAuthenticated();
    }

    match /attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    match /flags/{flagId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
