/**
 * Firebase Security Rules for Cryptic Hunt Application
 * 
 * Core Philosophy:
 * This ruleset implements a hybrid security model designed for a competitive cryptic hunt. 
 * It prioritizes strict identity-based ownership for team progress while allowing 
 * administrators full oversight. Read access to game content (Levels and Hints) is 
 * dynamically granted based on the team's current progress state.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function getMyTeamData() {
      return get(/databases/$(database)/documents/teams/$(request.auth.uid)).data;
    }

    // --- Collection Rules ---

    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(teamId);
      allow update: if isOwner(teamId) || isAdmin();
      allow delete: if isAdmin();

      match /attempts/{attemptId} {
        allow get, list: if isOwner(teamId) || isAdmin();
        allow create, update: if isOwner(teamId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /levels/{levelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /hints/{hintId} {
        allow get, list: if isAdmin() || (isSignedIn() && resource.data.isReleased == true);
        allow create, update, delete: if isAdmin();
      }
    }

    match /admin_roles/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /admin_logs/{adminLogId} {
      allow read, write: if isAdmin();
    }

    match /flags/{flagId} {
      allow read, write: if isAdmin();
    }

    // --- Collection Group Rules ---
    
    match /{path=**}/attempts/{attemptId} {
      allow read: if isAdmin();
    }

    match /{path=**}/hints/{hintId} {
      allow read: if isAdmin() || isSignedIn();
    }
  }
}