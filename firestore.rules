
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a production environment with Firebase Auth Custom Claims:
      // return request.auth != null && request.auth.token.admin == true;
      // For this prototype, we'll allow administrative access if the UID is known or the email matches.
      return isAuthenticated() && (request.auth.token.email == "admins@intra-syntax.com" || request.auth.uid == "admin-root");
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated() && (request.auth.uid == teamId || isAdmin());
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == teamId);
    }

    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hints/{hintId} {
      allow read: if isAuthenticated() && (resource.data.isReleased == true || isAdmin());
      allow write: if isAdmin();
    }

    match /hintRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.teamId == request.auth.uid);
      allow write: if isAuthenticated();
    }

    match /attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    match /flags/{flagId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
