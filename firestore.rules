
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Identity-based admin check for prototype
      return isAuthenticated() && (
        request.auth.token.email == "admin@intra-syntax.com" || 
        request.auth.token.email == "admins@intra-syntax.com"
      );
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated() && (request.auth.uid == teamId || isAdmin());
      // Allow teams to create their own record during first login
      allow write: if isAuthenticated() && (request.auth.uid == teamId || isAdmin());
    }

    match /levels/{levelId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /hints/{hintId} {
      allow read: if isAuthenticated() && (resource.data.isReleased == true || isAdmin());
      allow write: if isAdmin();
    }

    match /hintRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.teamId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.teamId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    match /flags/{flagId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
