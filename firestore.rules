
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(teamId) || isAdmin();
      allow update: if isOwner(teamId) || isAdmin();
      allow delete: if isAdmin();

      match /attempts/{attemptId} {
        allow get, list: if isOwner(teamId) || isAdmin();
        allow create, update: if isOwner(teamId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /levels/{levelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /hints/{hintId} {
        allow get, list: if isAdmin() || (isSignedIn() && resource.data.isReleased == true);
        allow create, update, delete: if isAdmin();
      }
    }

    match /admin_roles/{adminId} {
      // Allow any signed-in user to check if they are an admin
      allow get: if isSignedIn();
      // Allow the owner of the UID to create their own admin role for bootstrapping
      allow create: if isOwner(adminId);
      // Restricted operations for existing admins
      allow list, update, delete: if isAdmin();
    }

    match /admin_logs/{adminLogId} {
      allow read, write: if isAdmin();
    }

    match /flags/{flagId} {
      allow read, write: if isAdmin();
    }

    // --- Collection Group Rules ---
    
    match /{path=**}/attempts/{attemptId} {
      allow read: if isAdmin();
    }

    match /{path=**}/hints/{hintId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.isReleased == true);
    }
  }
}
