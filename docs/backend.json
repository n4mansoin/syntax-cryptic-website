
{
  "entities": {
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "Represents a participating team.",
      "properties": {
        "teamName": { "type": "string" },
        "currentLevel": { "type": "number" },
        "flagCount": { "type": "number" },
        "penaltyUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["teamName", "currentLevel", "flagCount"]
    },
    "Level": {
      "title": "Level",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["question", "order"]
    },
    "Hint": {
      "title": "Hint",
      "type": "object",
      "properties": {
        "levelId": { "type": "string" },
        "hintText": { "type": "string" },
        "isReleased": { "type": "boolean" },
        "releasedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["levelId", "hintText", "isReleased"]
    },
    "HintRequest": {
      "title": "HintRequest",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "levelId": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "levelId", "requestedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Team profiles."
    },
    "/levels/{levelId}": {
      "schema": { "$ref": "#/entities/Level" },
      "description": "Hunt levels."
    },
    "/hints/{hintId}": {
      "schema": { "$ref": "#/entities/Hint" },
      "description": "Cryptic hints for levels."
    },
    "/hintRequests/{requestId}": {
      "schema": { "$ref": "#/entities/HintRequest" },
      "description": "Flat collection of hint requests."
    }
  }
}
